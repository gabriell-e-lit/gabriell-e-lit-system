{
  "model": "AuthorModel",
  "version": "3.0",
  "description": "Unified author data model for gabriell-e-lit v12 architecture",
  "sections": {
    "seo": {
      "title": "string",
      "description": "string",
      "canonical_url": "string"
    },

    "identity": {
      "author_id": "string",
      "slug": "string",
      "name_original": "string",
      "name_display": "string"
    },

    "biography": {
      "short": "string",
      "long": "string",
      "quote": "string"
    },

    "photo": {
      "url": "string",
      "alt": "string"
    },

    "origin": {
      "country": "string",
      "city": "string",
      "birth_year": "string",
      "death_year": "string"
    },

    "links": {
      "tag_url": "string",
      "gallery_subcategory": "string",
