    "exhibitions": {
      "type": "list",
      "item_structure": {
        "exhibition_id": "string",
        "title": "string",
        "url": "string",
        "year": "string"
      }
    },

    "collections": {
      "type": "list",
      "item_structure": {
        "collection_id": "string",
        "title": "string",
        "url": "string",
        "year": "string"
      }
    },

    "navigation": {
      "alphabetical": "boolean"
    },

    "visual": {
      "show_quote": "boolean",
      "show_origin": "boolean",
      "show_gallery": "boolean",
      "show_publications": "boolean"
    }
